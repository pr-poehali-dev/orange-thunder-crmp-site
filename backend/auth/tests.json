      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Register new user",
      "method": "POST",
      "path": "/",
      "body": {"action": "register", "nickname": "TestPlayer99", "password": "secret123"},
      "expectedStatus": 200
    },
    {
      "name": "Login with correct credentials",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "nickname": "TestPlayer99", "password": "secret123"},
